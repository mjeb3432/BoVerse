# Copy this file to .env.local and fill in your keys. .env.local is gitignored.

# ─── LLM provider ──────────────────────────────────────────────────────────
# Google Gemini 2.0 Flash — primary LLM. Free tier: 15 req/min, 1M tokens/day.
# Get a key: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Groq Llama 3.3 70B — optional backup for speed-critical paths.
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# ─── Database + file storage ───────────────────────────────────────────────
# Supabase project. Free tier: 500MB Postgres + 1GB file storage + pgvector.
# Create a project: https://supabase.com/dashboard
# Then visit Project Settings → API to copy these values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
