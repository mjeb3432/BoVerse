# Copy this file to .env.local and fill in your keys. .env.local is gitignored.

# ─── LLM provider ──────────────────────────────────────────────────────────
# Google Gemini 2.0 Flash — primary LLM. Free tier: 15 req/min, 1M tokens/day.
# Get a key: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Groq Llama 3.3 70B — optional backup for speed-critical paths.
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# ─── Postgres ──────────────────────────────────────────────────────────────
# Your own Postgres connection string. Any Postgres works (Neon, Render,
# managed, self-hosted). Apply the schema with:
#   psql "$DATABASE_URL" -f migrations/0001_workflow_sessions.sql
DATABASE_URL=

# Set to "false" if your Postgres doesn't support SSL (self-hosted on
# trusted network). Defaults to SSL enabled for managed providers.
# PGSSL=false

# ─── python-docx sidecar ───────────────────────────────────────────────────
# URL of the python-docx renderer (see docx-service/). Stage 05 calls this
# to produce production-grade .docx output. Deploy from docx-service/ to
# Fly.io, then paste the resulting URL here.
DOCX_SERVICE_URL=
